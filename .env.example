# RevierApp — Beispiel-Umgebungsvariablen.
# Echte Werte stehen lokal in .env.local bzw. in Coolify (Production).
# Diese Datei dokumentiert NUR die Keys — niemals echte Secrets committen.

# --- Supabase (Pflicht) ---
# Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Sentry Error-Monitoring ---
# DSN ist oeffentlich (Client-seitig). Sentry -> Project Settings -> Client Keys (DSN).
NEXT_PUBLIC_SENTRY_DSN=
# Auth-Token NUR fuer Source-Map-Upload zur BUILD-Zeit (org:ci-Scope).
# In Coolify als Build-Env setzen — NICHT ins Repo. Sentry -> Settings -> Auth Tokens.
SENTRY_AUTH_TOKEN=
